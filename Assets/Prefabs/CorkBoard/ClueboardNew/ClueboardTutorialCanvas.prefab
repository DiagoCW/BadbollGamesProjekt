  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'CLUEBOARD: HOW TO USE



    TRANSFER CLUES: Click and drag items from
    your inventory onto the board.



    PLACE CLUES: Drag photos from the spawn
    tray into any empty slot on the board.



    FIND SUSPECTS: Explore the game
    to uncover suspects. They will automatically appear at the top of the board once
    discovered.



    CONNECT THREADS: Click and drag a red thread from a Suspect
    to a Clue to connect them.



    CUT STRINGS: Left-click any connected Clue
    to remove the connection.



    RETURN ITEMS: Right-click a Clue on the board
    to pack it up and send it back to your inventory.



    SOLVE THE CASE: To prove
    a suspect is guilty, connect 3 Clues to their photo. Once you do, the "Submit
    Solution" button will turn green. Click it to submit your evidence!'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 9c77d99a005c452478bbecfefb2d60d7, type: 2}
